{
  "name": "@sentryware/s2-node",
  "version": "0.0.7",
  "description": "Node.js JavaScript and TypeScript bindings for the Google S2 geolocation library.",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/sentryware/s2-node.git"
  },
  "scripts": {
    "build": "node-pre-gyp install --build-from-source",
    "install": "node-pre-gyp install --fallback-to-build",
    "test": "jest --logHeapUsage --verbose",
    "publish-to-s3": "node-pre-gyp package unpublish publish"
  },
  "author": "Jeff Kao (jeff@radar.com)",
  "license": "Apache-2.0",
  "keywords": [
    "geolocation"
  ],
  "devDependencies": {
    "aws-sdk": "2.x",
    "bindings": "^1.5.0",
    "jest": "^30.2.0"
  },
  "binary": {
    "module_name": "s2",
    "module_path": "./lib/binding/{configuration}/{node_abi}-{platform}-{arch}/",
    "remote_path": "./{module_name}/v{version}/{configuration}/",
    "package_name": "{module_name}-v{version}-{node_abi}-{platform}-{arch}.tar.gz",
    "host": "https://storage.googleapis.com",
    "bucket": "sentryware-s2-node",
    "region": "us-central1",
    "s3ForcePathStyle": true
  },
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "node-addon-api": "^8.6.0",
    "node-gyp": "^11.5.0"
  }
}
